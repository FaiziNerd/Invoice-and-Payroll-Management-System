# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local   (Mac/Linux)
#   copy .env.local.example .env.local (Windows)

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local app URL (share links & emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — invoice email (Resend)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=onboarding@resend.dev

# Optional — AI invoice draft (first match wins: xAI → Groq → OpenAI → Anthropic)
# xAI Grok (keys start with xai-)
# XAI_API_KEY=xai-...
# XAI_MODEL=grok-2-latest
# Groq fast inference (keys start with gsk_)
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Optional — migrations / scripts
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@...
# SUPABASE_DB_PASSWORD=your-db-password

# Optional — invoice email test script
# TEST_EMAIL_TO=you@example.com

# Optional — automated payment reminders cron (Vercel Cron / manual curl)
# CRON_SECRET=your-random-secret
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=onboarding@resend.dev
